FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    DOUYIN_MONITOR_WEB_HOST=0.0.0.0 \
    DOUYIN_MONITOR_WEB_PORT=8080 \
    DOUYIN_MONITOR_RUN_PATH=/data \
    PYTHONPATH=/app

ARG DEBIAN_MIRROR=
ARG PIP_INDEX_URL=https://pypi.org/simple
ENV PIP_INDEX_URL=${PIP_INDEX_URL}

WORKDIR /app

RUN if [ -n "$DEBIAN_MIRROR" ]; then \
        sed -i "s|http://deb.debian.org/debian|${DEBIAN_MIRROR}|g; s|http://deb.debian.org/debian-security|${DEBIAN_MIRROR}-security|g" /etc/apt/sources.list.d/debian.sources || true; \
    fi \
    && apt-get update \
    && apt-get install -y --no-install-recommends gcc g++ libglib2.0-0 libgl1 libnss3 libx11-6 libxext6 libxrender1 libsm6 libfontconfig1 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-web-docker.txt ./
RUN python -m pip install --upgrade pip setuptools wheel \
    && pip install --no-cache-dir -r requirements-web-docker.txt

COPY . .
RUN mkdir -p /data

EXPOSE 8080
CMD ["python", "-m", "scripts.run_web_server", "--host", "0.0.0.0", "--port", "8080", "--run-path", "/data"]
