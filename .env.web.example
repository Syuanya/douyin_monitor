# Linux Web deployment environment
DOUYIN_MONITOR_WEB_HOST=0.0.0.0
DOUYIN_MONITOR_WEB_PORT=8080
DOUYIN_MONITOR_RUN_PATH=/opt/douyin-monitor/data
# Set a long random token before exposing the service remotely.
DOUYIN_MONITOR_WEB_TOKEN=change-this-token
# Optional CORS allow-list, comma separated. Leave empty when using the bundled web UI.
DOUYIN_MONITOR_WEB_CORS=
